# Banco de dados (Supabase — pooler para runtime, direto para migrations)
DATABASE_URL="postgresql://postgres:[password]@[host]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@[host]:5432/postgres"

# Auth.js — gerar com `npx auth secret`
AUTH_SECRET=""

# Provider de e-mail (magic-link, ADL-109 — sem senha em nenhum realm)
RESEND_API_KEY=""
EMAIL_FROM="login@seudominio.com"

# Storage (Supabase Storage — ADR-04 original)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
